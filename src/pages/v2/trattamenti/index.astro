---
import BaseLayoutV2 from '../../../layouts/BaseLayoutV2.astro';
import LocationsV2 from '../../../components/v2/LocationsV2.astro';
import ContactFormV2 from '../../../components/v2/ContactFormV2.astro';
import { getCollection } from 'astro:content';

const trattamenti = await getCollection('trattamenti');

const categorie = [
  { id: 'pediatrica', label: 'Odontoiatria Pediatrica' },
  { id: 'ortodonzia', label: 'Ortodonzia' },
  { id: 'odontoiatria', label: 'Odontoiatria' },
  { id: 'estetica', label: 'Medicina Estetica' },
];

const byCat = (cat) =>
  trattamenti
    .filter((t) => t.data.categoria === cat)
    .sort((a, b) => a.data.ordine - b.data.ordine);

const title = 'Trattamenti — Centro Odontoiatrico BioDent';
const description = 'Tutti i trattamenti odontoiatrici di BioDent: pediatrica, ortodonzia, odontoiatria dell\'adulto e medicina estetica.';
---

<BaseLayoutV2 title={title} description={description} canonical="/trattamenti">
  <main>
    <section class="phead">
      <div class="wrap">
        <div class="crumbs"><span>Home</span><span>Trattamenti</span></div>
        <div class="phead-grid">
          <div data-reveal>
            <span class="eyebrow">Le nostre terapie</span>
            <h1>I nostri <em>trattamenti</em>.</h1>
          </div>
          <div data-reveal data-reveal-delay="1">
            <p class="lede">Dalla prima visita pediatrica all'implantologia, fino alla medicina estetica: protocolli specializzati in un unico centro.</p>
          </div>
        </div>
      </div>
    </section>

    {categorie.map((cat, i) => (
      <section class:list={['section', { soft: i % 2 === 1 }]} id={cat.id}>
        <div class="wrap">
          <div class="sec-head" data-reveal>
            <div>
              <span class="eyebrow">{cat.label}</span>
              <h2>{cat.label}.</h2>
            </div>
          </div>
          <div class="therapy-list" data-reveal>
            {byCat(cat.id).map((t) => (
              <a class="therapy" href={`/v2/trattamenti/${t.data.slug}`}>
                <span class="num">{String(t.data.ordine).padStart(2, '0')}</span>
                <h4>{t.data.title}</h4>
                <p>{t.data.descrizioneBreve}</p>
              </a>
            ))}
          </div>
        </div>
      </section>
    ))}

    <LocationsV2 tight />
    <ContactFormV2 />
  </main>
</BaseLayoutV2>
