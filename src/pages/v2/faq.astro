---
import BaseLayoutV2 from '../../layouts/BaseLayoutV2.astro';
import LocationsV2 from '../../components/v2/LocationsV2.astro';
import ContactFormV2 from '../../components/v2/ContactFormV2.astro';
import FaqAccordionV2 from '../../components/v2/FaqAccordionV2.astro';
import { faqPageJsonLd } from '../../lib/jsonld';
import sezioni from '../../data/faq-generali.json';

const title = 'Domande frequenti — BioDent';
const description =
  'Le risposte alle domande più frequenti dei pazienti del Centro Odontoiatrico BioDent: prima visita, sedi, costi, bambini, urgenze, tecnologie e prevenzione.';

const allItems = sezioni.flatMap((s) => s.items);
const faqLd = faqPageJsonLd(allItems, 'https://centrobiodent.net/faq');
---

<BaseLayoutV2 title={title} description={description} canonical="/faq">
  {faqLd && <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />}

  <main>
    <section class="phead">
      <div class="wrap">
        <div class="crumbs"><span>Home</span><span>FAQ</span></div>
        <div class="phead-grid">
          <div data-reveal>
            <span class="eyebrow">FAQ</span>
            <h1>Domande <em>frequenti</em>.</h1>
          </div>
          <div data-reveal data-reveal-delay="1">
            <p class="lede">Le risposte alle domande che ci fanno più spesso i pazienti al telefono e in studio, raggruppate per tema. Per tutto il resto, scrivici.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section soft">
      <div class="wrap narrow">
        {sezioni.map((s) => (
          <FaqAccordionV2 items={s.items} heading={s.title} />
        ))}
      </div>
    </section>

    <LocationsV2 tight />
    <ContactFormV2 />
  </main>
</BaseLayoutV2>
