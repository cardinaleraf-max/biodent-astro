---
import BaseLayoutV2 from '../../layouts/BaseLayoutV2.astro';
import LocationsV2 from '../../components/v2/LocationsV2.astro';
import ContactFormV2 from '../../components/v2/ContactFormV2.astro';
import content from '../../data/biodent-content.json';

const { services, marquee, media, contacts } = content;

const title = 'BioDent — Dentista a Sturno, Salerno e Napoli';
const description =
  'Centro Odontoiatrico BioDent della Dr.ssa Azzurra Di Cecilia. Odontoiatria pediatrica, ortodonzia, implantologia. Sedi a Sturno, Salerno e Napoli.';

const slugUrl = (slug) => `/v2/trattamenti/${slug}`;
const serviceSlugMap = {
  odontoiatria: 'implantologia',
  'odontoiatria-pediatrica': 'kids-cario-test-orto-test',
  ortodonzia: 'ortodonzia-intercettiva',
  'medicina-estetica': 'filler-labbra',
};
---

<BaseLayoutV2 title={title} description={description} canonical="/" image="/img/biodent-home-8.webp" transparentNav>
  <main>
    <!-- HERO -->
    <section class="hero">
      <video class="hero-video" autoplay muted loop playsinline poster={media.studioPhotos[0]}>
        <source src={media.videoHome} type="video/mp4" />
      </video>
      <div class="hero-scrim"></div>
      <div class="wrap hero-inner">
        <span class="eyebrow on-deep">Dr.ssa Azzurra Di Cecilia</span>
        <h1>Centro Odontoiatrico <em>Biodent</em></h1>
        <p class="hero-sub">Studi Dentistici a Sturno, Salerno e Napoli.</p>
        <div class="hero-actions">
          <a href={contacts.whatsappUrl} target="_blank" rel="noopener" class="btn btn-acc btn-lg">Scopri di più <span class="ar">→</span></a>
        </div>
      </div>
    </section>

    <!-- MARQUEE -->
    <div class="marq" aria-hidden="true">
      <div class="marq-track">
        <span class="grp">{marquee.map((m) => <span>{m}</span>)}</span>
        <span class="grp">{marquee.map((m) => <span>{m}</span>)}</span>
      </div>
    </div>

    <!-- SERVICES -->
    <section class="section">
      <div class="wrap">
        <div class="sec-head" data-reveal>
          <div>
            <span class="eyebrow">Le nostre terapie</span>
            <h2>Per la salute dentale di <em style="color:var(--acc-deep)">genitori e figli</em>.</h2>
          </div>
          <p class="lede">Dalla prima visita di un bambino di tre anni all'implantologia per un adulto: protocolli specializzati, tecnologie all'avanguardia e un approccio empatico costruito in 40 anni di pratica clinica.</p>
        </div>
        <div class="svc-grid" data-reveal>
          {services.map((s) => (
            <a class="svc" href={slugUrl(serviceSlugMap[s.slug])}>
              <span class="svc-num">{s.eyebrow}</span>
              <div class="svc-main">
                <h3>{s.title}</h3>
                <p>{s.desc}</p>
              </div>
              <span class="svc-go"><span class="ar">→</span></span>
              <div class="svc-thumb"><img src={s.img} alt={s.title} loading="lazy" /></div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ODONTOIATRIA PEDIATRICA -->
    <section class="section soft">
      <div class="wrap split">
        <div class="split-text" data-reveal>
          <span class="eyebrow">Odontoiatria infantile</span>
          <h2>Mamma e papà, da BioDent curiamo i denti <em>e il benessere</em> dei tuoi figli.</h2>
          <p class="sub">Dentisti per bambini a Sturno, Salerno e Napoli.</p>
          <p>Il Centro Odontoiatrico BioDent della Dr.ssa Azzurra Di Cecilia è un punto di riferimento per l'odontoiatria infantile a Sturno, Salerno e Napoli. Siamo partner di spicco del network <em style="font-style:italic">Dentista Dei Bambini</em>, la rete nazionale che riunisce solo gli studi dentistici che eccellono nelle cure dentali pediatriche per approccio e protocolli.</p>
          <a href="/v2/odontoiatria-pediatrica" class="btn btn-dark">Vai all'odontoiatria pediatrica <span class="ar">→</span></a>
        </div>
        <div class="split-media" data-reveal data-reveal-delay="1">
          <img src={media.studioPhotos[0]} alt="Studio dentistico BioDent — odontoiatria pediatrica Sturno Salerno Napoli" loading="lazy" />
          <span class="badge">Studio Biodent</span>
        </div>
      </div>
    </section>

    <!-- BIODENT + DENTISTA DEI BAMBINI -->
    <section class="section">
      <div class="wrap split reverse">
        <div class="split-media" data-reveal>
          <img src={media.studioPhotos[1]} alt="Collaborazione BioDent e Dentista dei Bambini — network nazionale pedodonzia" loading="lazy" />
          <span class="badge">Dentista dei Bambini</span>
        </div>
        <div class="split-text" data-reveal data-reveal-delay="1">
          <span class="eyebrow">La partnership</span>
          <h2>BioDent + Il Dentista Dei Bambini.</h2>
          <p class="sub">Insieme per la salute dentale dei più piccoli.</p>
          <p>La collaborazione tra BioDent e il <em style="font-style:italic">Dentista Dei Bambini</em> è nata per garantire ai genitori una doppia tranquillità riguardo al sorriso dei loro figli. Oltre alla nostra ventennale esperienza, siamo stati scelti come eccellenza nel campo dell'odontoiatria infantile. Ecco alcuni dei nostri punti di forza:</p>
          <ul class="deflist">
            <li><strong>Tell-Show-Do</strong><span class="t">Tramite spiegazione, dimostrazione e un'esecuzione delicata del trattamento riduciamo l'ansia nei bambini.</span></li>
            <li><strong>Kids Cario Test · Orto Test</strong><span class="t">Valutiamo la salute orale in modo rapido e approfondito, anche con il test salivare.</span></li>
            <li><strong>Ozonoterapia</strong><span class="t">Usiamo l'ozono per disinfettare le carie, riducendo gli interventi invasivi e favorendo una guarigione rapida.</span></li>
            <li><strong>Special needs</strong><span class="t">Curiamo i bambini con bisogni speciali grazie a protocolli testati e certificati con sedazione.</span></li>
          </ul>
          <a href="/v2/odontoiatria-pediatrica" class="btn btn-dark" style="margin-top:26px">BioDent è il dentista dei bambini <span class="ar">→</span></a>
        </div>
      </div>
    </section>

    <!-- PERCHÉ SCEGLIERE BIODENT -->
    <section class="section soft">
      <div class="wrap split">
        <div class="split-text" data-reveal>
          <span class="eyebrow">Il nostro approccio</span>
          <h2>Perché scegliere BioDent per i tuoi figli.</h2>
          <p class="sub">Approccio delicato e rassicurante per i piccoli pazienti.</p>
          <p>Le cure dentali per i bambini richiedono attenzione al benessere psicologico e al comfort dei più piccoli, oltre che competenze specifiche. La Dr.ssa Azzurra Di Cecilia adotta un approccio psicologico che aiuta i piccoli pazienti a sentirsi a loro agio e a non temere le visite dentistiche, combinato a protocolli di <em style="font-style:italic">Sedazione Cosciente</em> sicuri ed efficaci, con cui i bambini si rilassano e avvertono limitatamente il dolore.</p>
          <p class="strong-line">Scegli i professionisti dell'odontoiatria pediatrica per i tuoi bambini.</p>
        </div>
        <div class="split-media" data-reveal data-reveal-delay="1">
          <img src={media.studioPhotos[2]} alt="Sala operatoria Studio BioDent — sedazione cosciente per bambini" loading="lazy" />
          <span class="badge">Sedazione cosciente</span>
        </div>
      </div>
    </section>

    <!-- ORTODONZIA -->
    <section class="section">
      <div class="wrap split reverse">
        <div class="split-media" data-reveal>
          <img src="/img/biodent-home-25.webp" alt="Allineatori trasparenti ortodonzia — BioDent Napoli Salerno Sturno" loading="lazy" />
          <span class="badge">Allineatori trasparenti</span>
        </div>
        <div class="split-text" data-reveal data-reveal-delay="1">
          <span class="eyebrow">Ortodonzia</span>
          <h2>Ortodonzia intercettiva, fissa e <em>invisibile</em>.</h2>
          <p class="sub">Interveniamo a ogni età per garantire denti dritti e un sorriso sano.</p>
          <p>Con l'ortodonzia intercettiva preveniamo e correggiamo precocemente le problematiche dentali nei più piccoli, evitando trattamenti futuri più invasivi. Per adolescenti e adulti impieghiamo apparecchi fissi o allineatori trasparenti, che garantiscono discrezione e comfort, per una terapia serena e un sorriso perfetto.</p>
          <a href="/v2/ortodonzia" class="btn btn-dark">Ortodonzia <span class="ar">→</span></a>
        </div>
      </div>
    </section>

    <!-- ODONTOIATRIA DELL'ADULTO -->
    <section class="section soft">
      <div class="wrap split">
        <div class="split-text" data-reveal>
          <span class="eyebrow">Odontoiatria</span>
          <h2>Odontoiatria dell'adulto.</h2>
          <p class="sub">Cure dentali avanzate, dagli impianti alle faccette dentali.</p>
          <p>Con le nostre tecniche di implantologia e chirurgia orale ripristiniamo la funzionalità e l'estetica del tuo sorriso in modo sicuro e duraturo. Non solo salute, ma anche bellezza: con i trattamenti di estetica dentale come le faccette dentali, il tuo sorriso sarà luminoso e in perfetta armonia.</p>
          <a href="/v2/odontoiatria" class="btn btn-dark">Odontoiatria generale <span class="ar">→</span></a>
        </div>
        <div class="split-media" data-reveal data-reveal-delay="1">
          <img src="/img/odontoiatria-12.webp" alt="Odontoiatria implantologia adulti — Studio BioDent" loading="lazy" />
          <span class="badge">Implantologia</span>
        </div>
      </div>
    </section>

    <!-- MEDICINA ESTETICA -->
    <section class="section">
      <div class="wrap split reverse">
        <div class="split-media" data-reveal>
          <img src="/img/biodent-home-19.webp" alt="Filler labbra e medicina estetica — BioDent" loading="lazy" />
          <span class="badge">Medicina estetica</span>
        </div>
        <div class="split-text" data-reveal data-reveal-delay="1">
          <span class="eyebrow">Medicina estetica</span>
          <h2>Medicina estetica ad Avellino, Salerno e Napoli.</h2>
          <p class="sub">Valorizziamo la tua naturale bellezza con trattamenti antiage.</p>
          <p>I nostri filler e trattamenti di medicina estetica riducono le rughe e ridefiniscono i contorni del viso per un aspetto fresco e naturale. Con la biorivitalizzazione restituiamo alla tua pelle tonicità e idratazione profonda, per un risultato giovane e luminoso.</p>
          <a href="/v2/medicina-estetica" class="btn btn-dark">Medicina estetica <span class="ar">→</span></a>
        </div>
      </div>
    </section>

    <LocationsV2 />
    <ContactFormV2 />
  </main>
</BaseLayoutV2>
