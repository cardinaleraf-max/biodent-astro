---
import BaseLayoutV2 from '../../layouts/BaseLayoutV2.astro';
import PageHeadV2 from '../../components/v2/PageHeadV2.astro';
import CategoriaTrattamentiV2 from '../../components/v2/CategoriaTrattamentiV2.astro';
import LocationsV2 from '../../components/v2/LocationsV2.astro';
import ContactFormV2 from '../../components/v2/ContactFormV2.astro';

const title = 'Ortodonzia e Allineatori Trasparenti — BioDent';
const description =
  'Ortodonzia intercettiva, fissa e allineatori trasparenti a Sturno, Salerno e Napoli. Sorriso dritto a ogni età con i nostri specialisti.';
---

<BaseLayoutV2 title={title} description={description} canonical="/ortodonzia" image="/img/biodent-home-23.webp">
  <main>
    <PageHeadV2
      crumbs={['Home', 'Terapie', 'Ortodonzia']}
      kicker="Specialisti in Ortodonzia"
      title="<em>Ortodonzia</em> a Sturno, Salerno e Napoli."
      lead="Al Centro Odontoiatrico Biodent della Dr.ssa Azzurra Di Cecilia, eseguiamo trattamenti ortodontici su misura per ogni fase di crescita, aiutando bambini, adolescenti e adulti ad ottenere denti dritti e un sorriso sano e armonioso."
    />

    <!-- Introduzione di categoria -->
    <section class="section">
      <div class="wrap split">
        <div class="split-text" data-reveal>
          <span class="eyebrow">Prevenzione precoce per un sorriso in crescita</span>
          <h2>Intervenire <em>presto</em>, per non doverlo fare dopo.</h2>
          <p>L'ortodonzia intercettiva si occupa della correzione precoce delle anomalie dentali e scheletriche nei bambini. Raccomandiamo di considerare l'ortodonzia intercettiva per i bambini tra i 5 e gli 11 anni, con una prima visita intorno ai 6 anni — e interventi precoci già a 4–5 anni se necessario.</p>
          <p>Per adolescenti e adulti impieghiamo apparecchi fissi o allineatori trasparenti, che garantiscono discrezione e comfort, per una terapia serena e un sorriso perfetto.</p>
        </div>
        <div class="split-media" data-reveal data-reveal-delay="1">
          <img src="/img/biodent-home-25.webp" alt="Allineatori trasparenti Invisalign — BioDent provider certificato" loading="lazy" />
          <span class="badge">Biodent — Provider Invisalign</span>
        </div>
      </div>
    </section>

    <!-- Trattamenti della categoria -->
    <section class="section soft">
      <div class="wrap">
        <div class="sec-head" data-reveal>
          <div>
            <span class="eyebrow">I nostri trattamenti</span>
            <h2>Per ogni occlusione, la sua terapia.</h2>
          </div>
          <p class="lede">Un percorso ortodontico completo dalla prima visita al fine terapia, con tecnologie d'avanguardia e specialisti dedicati.</p>
        </div>
        <CategoriaTrattamentiV2 categoria="ortodonzia" />
      </div>
    </section>

    <!-- IL PERCORSO CON GLI ALLINEATORI -->
    <section class="section">
      <div class="wrap">
        <div class="sec-head" data-reveal>
          <div>
            <span class="eyebrow">Allineatori trasparenti</span>
            <h2>Un sorriso dritto, in modo <em style="color:var(--acc-deep)">invisibile</em>.</h2>
          </div>
          <p class="lede">Mascherine su misura, removibili e quasi invisibili, per raddrizzare i denti continuando a vivere e mangiare normalmente. Da BioDent, provider Invisalign, il percorso è interamente digitale.</p>
        </div>
        <div class="process" data-reveal>
          <div class="step">
            <div class="sn">01</div>
            <h3>Scansione digitale</h3>
            <p>Tutto parte da una scansione 3D della bocca, veloce e senza paste né impronte tradizionali, più precisa e confortevole.</p>
          </div>
          <div class="step">
            <div class="sn">02</div>
            <h3>Pianificazione e anteprima</h3>
            <p>Sul modello digitale l'ortodontista progetta l'intero trattamento e, in molti casi, ti mostra in anteprima il sorriso finale prima ancora di iniziare.</p>
          </div>
          <div class="step">
            <div class="sn">03</div>
            <h3>Allineatori e contenzione</h3>
            <p>Indossi gli allineatori su misura in sequenza, cambiandoli periodicamente, fino alla contenzione finale che fissa il risultato nel tempo.</p>
          </div>
        </div>
      </div>
    </section>

    <LocationsV2 tight />
    <ContactFormV2 />
  </main>
</BaseLayoutV2>
