---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Locations from '../../components/Locations.astro';
import ContactForm from '../../components/ContactForm.astro';
import FaqAccordion from '../../components/FaqAccordion.astro';
import { getCollection, render } from 'astro:content';
import { faqPageJsonLd, trattamentoJsonLd } from '../../lib/jsonld';

export async function getStaticPaths() {
  const trattamenti = await getCollection('trattamenti');
  return trattamenti.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const d = entry.data;

const catLabel = {
  pediatrica: 'Odontoiatria Pediatrica',
  ortodonzia: 'Ortodonzia',
  odontoiatria: 'Odontoiatria',
  estetica: 'Medicina Estetica',
};

const pageUrl = `https://centrobiodent.net/trattamenti/${d.slug}`;
const faqItems = d.faq ?? [];
const faqLd = faqPageJsonLd(faqItems, pageUrl);
const procLd = trattamentoJsonLd({
  title: d.title,
  description: d.metaDescription,
  url: pageUrl,
  image: `https://centrobiodent.net${d.immagine}`,
});
---

<BaseLayout
  title={`${d.title} — BioDent`}
  description={d.metaDescription}
  canonical={`/trattamenti/${d.slug}`}
  image={d.immagine}
>
  <Fragment slot="jsonld">
    <script type="application/ld+json" set:html={JSON.stringify(procLd)} />
    {faqLd && <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />}
  </Fragment>

  <main class="page-enter">
    <section class="page-head">
      <div class="container-wide">
        <div class="crumbs">
          <span>Home</span><span>Trattamenti</span><span>{catLabel[d.categoria]}</span>
        </div>
        <div class="page-head-grid">
          <div>
            <span class="eyebrow" style="margin-bottom: 16px; display: inline-flex;">{catLabel[d.categoria]}</span>
            <h1>{d.title}</h1>
          </div>
          <div>
            <p>{d.descrizioneBreve}</p>
            <div style="margin-top: 28px; display: flex; gap: 12px;">
              <a href="/contatti" class="btn">Prenota una visita
                <svg class="arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="18" x2="18" y2="6"/><polyline points="9,6 18,6 18,15"/></svg>
              </a>
              <a href="/trattamenti" class="btn btn-outline">Tutti i trattamenti</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <figure class="article-hero">
          <img src={d.immagine} alt={d.title} />
        </figure>
        <article class="article-body">
          <Content />
        </article>
      </div>
    </section>

    {faqItems.length > 0 && (
      <section class="section" style="background: var(--bg-alt);">
        <div class="container">
          <div class="sec-head">
            <div class="left">
              <span class="eyebrow">FAQ</span>
              <h2>Domande<br />frequenti.</h2>
            </div>
            <p>Le risposte alle domande più comuni su questo trattamento. Per ogni dubbio, scrivici o prenota una visita.</p>
          </div>
          <FaqAccordion items={faqItems} />
        </div>
      </section>
    )}

    <Locations tight />
    <ContactForm />
  </main>
</BaseLayout>
