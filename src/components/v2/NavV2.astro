---
import content from '../../data/biodent-content.json';

interface Props {
  /** transparent over a dark hero until scrolled */
  transparent?: boolean;
}
const { transparent = false } = Astro.props;
const { contacts, social } = content;

const nav = [
  { p: '/v2/', l: 'Home' },
  { p: '/v2/chi-siamo', l: 'Chi siamo' },
  { p: '/v2/perche-biodent', l: 'Perché BioDent' },
  {
    l: 'Terapie',
    children: [
      { p: '/v2/odontoiatria-pediatrica', l: 'Odontoiatria Pediatrica', m: 'Per i bambini · Sedazione cosciente' },
      { p: '/v2/ortodonzia', l: 'Ortodonzia', m: 'Intercettiva, fissa, allineatori' },
      { p: '/v2/odontoiatria', l: 'Odontoiatria', m: 'Implantologia, conservativa, protesi' },
      { p: '/v2/trattamenti', l: 'Tutti i trattamenti', m: 'Panoramica completa delle terapie' },
    ],
  },
  { p: '/v2/medicina-estetica', l: 'Medicina estetica' },
  { p: '/v2/tecnologie', l: 'Tecnologie' },
  { p: '/v2/contatti', l: 'Contatti' },
];

const path = Astro.url.pathname.replace(/\/$/, '') || '/v2';
const active = (p) => {
  const c = p.replace(/\/$/, '');
  return c === path || (c !== '/v2' && path.startsWith(c));
};
---

<header class:list={['nav', { 'at-top': transparent }]} data-nav data-transparent={transparent}>
  <div class="wrap nav-inner">
    <a href="/v2/" class="nav-brand" aria-label="BioDent — Home">
      <img src={contacts.logo} alt="BioDent Centro Odontoiatrico" />
    </a>

    <nav class="nav-links">
      {nav.map((it) => it.children ? (
        <div class="nav-grp" data-grp>
          <button type="button" data-grp-toggle>{it.l}<span class="cv"></span></button>
          <div class="nav-menu">
            {it.children.map((c) => (
              <a href={c.p}><strong>{c.l}</strong><span class="m">{c.m}</span></a>
            ))}
          </div>
        </div>
      ) : (
        <a href={it.p} class:list={[{ active: active(it.p) }]}>{it.l}</a>
      ))}
    </nav>

    <div class="nav-cta">
      <a href={`tel:${contacts.primaryPhone.replace(/\s/g, '')}`} class="nav-phone">{contacts.primaryPhone}</a>
      <a href="/v2/contatti" class="btn btn-acc">Prenota</a>
      <button class="nav-burger" aria-label="Apri menu" data-burger><span></span><span></span></button>
    </div>
  </div>
</header>

<div class="nav-mobile" data-mobile>
  <nav class="nm-links">
    {nav.map((it) => it.children ? (
      <div class="nm-group">
        <span class="nm-label">{it.l}</span>
        {it.children.map((c) => <a href={c.p} class="nm-sub">{c.l}</a>)}
      </div>
    ) : (
      <a href={it.p}>{it.l}</a>
    ))}
  </nav>
  <div class="nm-foot">
    <a href={`tel:${contacts.primaryPhone.replace(/\s/g, '')}`} class="nm-phone">{contacts.primaryPhone}</a>
    <div class="nm-cta">
      <a href={contacts.whatsappUrlPrefilled} target="_blank" rel="noopener noreferrer" class="btn btn-ghost">WhatsApp</a>
      <a href="/v2/contatti" class="btn btn-acc">Prenota una visita</a>
    </div>
    <div class="nm-social">
      <a href={social.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
      </a>
      <a href={social.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook">
        <svg viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
      </a>
    </div>
  </div>
</div>

<script>
  const nav = document.querySelector('[data-nav]') as HTMLElement | null;
  const transparent = nav?.dataset.transparent === 'true';

  const onScroll = () => {
    if (!nav) return;
    const scrolled = window.scrollY > 40;
    nav.classList.toggle('scrolled', scrolled);
    if (transparent) nav.classList.toggle('at-top', !scrolled);
  };
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  document.querySelectorAll('[data-grp]').forEach((g) => {
    g.querySelector('[data-grp-toggle]')?.addEventListener('click', (e) => {
      e.stopPropagation();
      document.querySelectorAll('[data-grp]').forEach((o) => o !== g && o.classList.remove('open'));
      g.classList.toggle('open');
    });
  });
  document.addEventListener('click', () => document.querySelectorAll('[data-grp].open').forEach((g) => g.classList.remove('open')));

  const burger = document.querySelector('[data-burger]');
  const mobile = document.querySelector('[data-mobile]');
  const setMenu = (open: boolean) => {
    mobile?.classList.toggle('open', open);
    burger?.classList.toggle('open', open);
    nav?.classList.toggle('menu-open', open);
    document.body.style.overflow = open ? 'hidden' : '';
  };
  burger?.addEventListener('click', () => setMenu(!mobile?.classList.contains('open')));
  mobile?.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setMenu(false)));
</script>
