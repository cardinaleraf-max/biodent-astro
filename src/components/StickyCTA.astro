---

<div class="sticky-cta" data-sticky-cta>
  <button class="cta-close" aria-label="Chiudi" data-cta-close>
    <svg width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round">
      <line x1="1" y1="1" x2="9" y2="9" /><line x1="9" y1="1" x2="1" y2="9" />
    </svg>
  </button>
  <span class="label">Hai una <strong>domanda</strong>? Ti richiamiamo noi.</span>
  <a href="/contatti" class="btn">Prenota una visita
    <svg class="arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="18" x2="18" y2="6"/><polyline points="9,6 18,6 18,15"/></svg>
  </a>
</div>

<script>
  const cta = document.querySelector('[data-sticky-cta]');
  let dismissed = false;
  const onScroll = () => {
    if (!cta || dismissed) return;
    const show = window.scrollY > 600 && window.scrollY < document.body.scrollHeight - window.innerHeight - 400;
    cta.classList.toggle('show', show);
  };
  document.querySelector('[data-cta-close]')?.addEventListener('click', () => {
    dismissed = true;
    cta?.classList.remove('show');
  });
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();
</script>
