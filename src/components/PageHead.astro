---
import content from '../data/biodent-content.json';
const { contacts } = content;

interface Props {
  crumbs: string[];
  kicker: string;
  /** Title may contain inline <em> / <br/> markup */
  title: string;
  lead: string;
}
const { crumbs, kicker, title, lead } = Astro.props;
---

<section class="page-head">
  <div class="container-wide">
    <div class="crumbs">{crumbs.map((c) => <span>{c}</span>)}</div>
    <div class="page-head-grid">
      <div>
        <span class="eyebrow" style="margin-bottom: 16px; display: inline-flex;">{kicker}</span>
        <h1 set:html={title} />
      </div>
      <div>
        <p>{lead}</p>
        <div style="margin-top: 28px; display: flex; gap: 12px;">
          <a href="/contatti" class="btn">Prenota una visita
            <svg class="arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="18" x2="18" y2="6"/><polyline points="9,6 18,6 18,15"/></svg>
          </a>
          <a href={contacts.whatsappUrlPrefilled} target="_blank" rel="noopener noreferrer" class="btn btn-outline">WhatsApp
            <svg class="arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><line x1="6" y1="18" x2="18" y2="6"/><polyline points="9,6 18,6 18,15"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
