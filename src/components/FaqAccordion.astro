---
import type { FaqItem } from '../lib/jsonld';

interface Props {
  items: FaqItem[];
  /** Titolo opzionale della sezione (es. eyebrow) */
  heading?: string;
}
const { items, heading } = Astro.props;
---

{items.length > 0 && (
  <div class="faq">
    {heading && <h3 class="faq-group-title">{heading}</h3>}
    {items.map((f) => (
      <details class="faq-item">
        <summary>
          <span>{f.q}</span>
          <span class="plus"></span>
        </summary>
        <p class="answer">{f.a}</p>
      </details>
    ))}
  </div>
)}

<style>
  .faq-group-title {
    font-family: var(--display);
    font-size: clamp(20px, 1.8vw, 26px);
    margin: 32px 0 8px;
    color: var(--ink);
  }
</style>
